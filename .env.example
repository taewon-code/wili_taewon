# Anthropic(Claude) API 키 — https://console.anthropic.com 에서 발급
# 이 파일을 복사해 `.env.local` 로 만들고 실제 키를 넣으세요.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (선택) Notion 가져오기 — https://www.notion.so/my-integrations 에서
# 인티그레이션을 만들고 토큰을 발급한 뒤, 가져올 페이지를 그 인티그레이션과 공유하세요.
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
